doctype html
html(lang='en')

    head

        meta(charset='utf-8')
        meta(name='viewport', content='width=device-width, initial-scale=1, shrink-to-fit=no')
        meta(name='description', content='View the Sweet Chiefs menu — Nashville-style hot chicken sandwiches, nuggs, tots, and more. Choose your heat level from Easy to Mythic.')
        meta(name='author', content='Sweet Chiefs LLC')

        title Sweet Chiefs - Hot Chicken Menu

        // Canonical
        link(rel='canonical', href='https://www.sweetchiefs.com/menu/')

        // Favicon
        link(rel='icon', type='image/x-icon', href='assets/favicon.ico')

        // Open Graph
        meta(property='og:type', content='website')
        meta(property='og:site_name', content='Sweet Chiefs')
        meta(property='og:title', content='Sweet Chiefs - Hot Chicken Menu')
        meta(property='og:description', content='View the Sweet Chiefs menu — Nashville-style hot chicken sandwiches, nuggs, tots, and more. Choose your heat level from Easy to Mythic.')
        meta(property='og:url', content='https://www.sweetchiefs.com/menu/')
        meta(property='og:image', content='https://www.sweetchiefs.com/assets/img/mauve_logo_white_text.png')

        // Twitter Card
        meta(name='twitter:card', content='summary_large_image')
        meta(name='twitter:title', content='Sweet Chiefs - Hot Chicken Menu')
        meta(name='twitter:description', content='View the Sweet Chiefs menu — Nashville-style hot chicken sandwiches, nuggs, tots, and more. Choose your heat level from Easy to Mythic.')
        meta(name='twitter:image', content='https://www.sweetchiefs.com/assets/img/mauve_logo_white_text.png')

        // Font Awesome icons (free version)
        script(src='https://use.fontawesome.com/releases/v6.3.0/js/all.js', crossorigin='anonymous')

        // Google fonts
        link(rel='preconnect', href='https://fonts.googleapis.com')
        link(rel='preconnect', href='https://fonts.gstatic.com', crossorigin='')
        link(href='https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Lato:ital,wght@0,400;0,700;1,400;1,700&display=swap', rel='stylesheet')

        // Core theme CSS (includes Bootstrap)
        link(href='../css/styles.css', rel='stylesheet')

    body#page-top
        nav#mainNav.navbar.navbar-expand-lg.bg-secondary.text-uppercase.fixed-top
            .container
                a.navbar-brand(href='../') Sweet Chiefs

        header.masthead.bg-primary.text-white.text-center
            .container.d-flex.align-items-center.flex-column
                h1.masthead-heading.text-uppercase.mb-0 Sweet Chiefs Menu
                .divider-custom.divider-light
                    .divider-custom-line
                    .divider-custom-icon
                        i.fas.fa-pepper-hot
                    .divider-custom-line

        include ../includes/menu.pug